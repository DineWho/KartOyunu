{
  "expo": {
    "name": "CardWho",
    "slug": "cardwho",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7B35CC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.erikmedya.cardwho"
    },
    "android": {
      "package": "com.erikmedya.cardwho",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7B35CC"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
